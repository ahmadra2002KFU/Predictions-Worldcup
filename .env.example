# --- Database ---
POSTGRES_DB=mufeed
POSTGRES_USER=mufeed
# Use a URL-safe value (hex) — avoids escaping issues in DATABASE_URL.
# Generate: openssl rand -hex 32
POSTGRES_PASSWORD=changeme-openssl-rand-hex-32

# --- App secrets (server-only, never prefixed NEXT_PUBLIC_) ---
# Admin panel password. Generate: openssl rand -hex 32
ADMIN_SECRET=changeme-openssl-rand-hex-32
# Cookie sealing key, must be >= 32 chars. Generate: openssl rand -hex 32
SESSION_SECRET=changeme-openssl-rand-hex-32

# --- Public / deployment ---
# The public URL of the site (used for absolute links). Safe to expose to the browser.
NEXT_PUBLIC_SITE_URL=https://predictions.example.com
# The domain Caddy will obtain a TLS certificate for (no protocol).
SITE_DOMAIN=predictions.example.com

NODE_ENV=production
TZ=UTC

# --- Local dev only (running `npm run dev` outside Docker) ---
# Not needed in the Docker production stack (the app service builds DATABASE_URL itself).
# DATABASE_URL=postgresql://mufeed:changeme@localhost:5432/mufeed
